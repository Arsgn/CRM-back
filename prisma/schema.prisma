generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum UserRole {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

enum PaymentMethod {
  CASH
  CARD
}

enum AppointmentStatus {
  WAITING     // Живая очередь
  SCHEDULED   // Запись
  CANCELLED   // Отменена
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── USER (врачи, администраторы, регистраторы) ──────────

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String?
  avatar    String?
  phone     String?
  role      UserRole  @default(RECEPTIONIST)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Если роль DOCTOR
  doctorProfile DoctorProfile?
  appointments  Appointment[]  @relation("DoctorAppointments")
  schedules     Schedule[]

  @@map("users")
}

// ─── DOCTOR PROFILE ──────────────────────────────────────

model DoctorProfile {
  id         Int    @id @default(autoincrement())
  userId     Int    @unique
  user       User   @relation(fields: [userId], references: [id])
  speciality String // Кардиолог, Невролог и т.д.
  cabinet    String?
  experience Int?   // лет опыта

  @@map("doctor_profiles")
}

// ─── PATIENT (клиент) ────────────────────────────────────

model Patient {
  id          Int       @id @default(autoincrement())
  fullName    String
  phone       String?
  birthDate   DateTime?
  gender      String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  appointments Appointment[]

  @@map("patients")
}

// ─── CATEGORY (отделение) ────────────────────────────────

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique  // Кардиология, Терапия, Неврология...
  createdAt DateTime  @default(now())

  services  Service[]

  @@map("categories")
}

// ─── PRICE LIST (прайс лист) ─────────────────────────────

model Service {
  id         Int      @id @default(autoincrement())
  name       String               // Первичный приём, Консультация...
  price      Float
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  appointmentServices AppointmentService[]

  @@map("services")
}

// ─── APPOINTMENT (запись клиента) ────────────────────────

model Appointment {
  id        Int               @id @default(autoincrement())
  patientId Int
  patient   Patient           @relation(fields: [patientId], references: [id])
  doctorId  Int
  doctor    User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  date      DateTime
  timeStart String            // "10:00"
  timeEnd   String            // "11:00"
  status    AppointmentStatus @default(SCHEDULED)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  payment             Payment?
  appointmentServices AppointmentService[]

  @@map("appointments")
}

// ─── APPOINTMENT <-> SERVICE (many-to-many) ───────────────

model AppointmentService {
  id            Int         @id @default(autoincrement())
  appointmentId Int
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  serviceId     Int
  service       Service     @relation(fields: [serviceId], references: [id])

  @@map("appointment_services")
}

// ─── PAYMENT (оплата) ────────────────────────────────────

model Payment {
  id            Int           @id @default(autoincrement())
  appointmentId Int           @unique
  appointment   Appointment   @relation(fields: [appointmentId], references: [id])
  amount        Float
  method        PaymentMethod @default(CASH)
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  @@map("payments")
}

// ─── SCHEDULE (календарь врача) ──────────────────────────

model Schedule {
  id        Int      @id @default(autoincrement())
  doctorId  Int
  doctor    User     @relation(fields: [doctorId], references: [id])
  dayOfWeek Int      // 0=Пн, 1=Вт ... 6=Вс
  timeStart String   // "08:00"
  timeEnd   String   // "18:00"
  createdAt DateTime @default(now())

  @@map("schedules")
}

// ─── ANALYTICS (сводная аналитика по дням) ───────────────

model AnalyticsSnapshot {
  id             Int      @id @default(autoincrement())
  date           DateTime @unique
  totalRevenue   Float    @default(0)
  totalPatients  Int      @default(0)
  totalCompleted Int      @default(0)
  totalCancelled Int      @default(0)
  createdAt      DateTime @default(now())

  @@map("analytics_snapshots")
}